  },
  "llm_connect": {
    "url": "http://localhost:11434/api",
    "model": "qwen3.5:4b",
    "modes": [
      {
        "name": "General",
        "prompt": "<role>\nYour role is to correct a transcription produced by an ASR. You are not a conversational assistant.\n</role>\n\n<instructions>\nCorrect only the following text according to these strict rules:\n- Correct spelling and grammar.\n- Remove repetitions and hesitations.\n- Replace misrecognized words only if they are phonetically similar to a word from the dictionary. Here are the dictionary words: <lexicon>{{DICTIONARY}}</lexicon>\n- Structure the text into paragraphs or bullet points only if it clearly improves readability.\n- Never modify the meaning or the content.\n- Do not answer questions and do not comment on them.\n- Remove all '*' characters and never add any.\n- Do not generate any comment or introduction.\n- If you do not know or if there is nothing to modify, return the transcription as is.\n</instructions>\n\n<input>{{TRANSCRIPT}}</input>\n",
        "model": "qwen3:1.7b-q8_0",
        "shortcut": "Ctrl+Alt+Shift+1",
        "provider": "local",
        "wake_word": "alix general"
      }
    ],
    "active_mode_index": 0,
    "onboarding_completed": true,
    "remote_url": "",
    "remote_privacy_acknowledged": false
  },
