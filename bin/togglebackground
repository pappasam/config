#!/bin/bash

set -euo pipefail

dark="$HOME/.config/kitty/papercolor-dark.conf"
light="$HOME/.config/kitty/papercolor-light.conf"

socket="${KITTY_LISTEN_ON:-}"
if [[ -z "$socket" ]]; then
  for candidate in /tmp/kitty-*; do
    [[ -S "$candidate" ]] && socket="unix:$candidate" && break
  done
fi

[[ -n "$socket" ]] || exit 1

theme="$dark"
current_background="$(kitty @ --to "$socket" get-colors --configured | awk '$1 == "background" { print $2; exit }')"
dark_background="$(awk '$1 == "background" { print $2; exit }' "$dark")"
[[ "$current_background" == "$dark_background" ]] && theme="$light"

mapfile -t colors < <(
  awk '/^(foreground|background|cursor|color[0-9]+)[[:space:]]/ { print $1 "=" $2 }' "$theme"
)

kitty @ --to "$socket" set-colors --all --configured "${colors[@]}"
